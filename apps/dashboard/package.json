{
  "name": "@8xd/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:attribution": "vitest run tests/ai-attribution.test.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "worker:dev": "wrangler dev --local --port 8787",
    "deploy:dry": "wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply 8xd_dashboard_metrics --local",
    "db:migrate:remote": "wrangler d1 migrations apply 8xd_dashboard_metrics --remote",
    "types:cf": "wrangler types src/worker/env.d.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "@vitejs/plugin-react": "^5.1.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15",
    "wrangler": "^4.100.0"
  }
}
